load('ext://git_resource', 'git_checkout')
load('ext://namespace', 'namespace_create', 'namespace_inject')
load('ext://helm_remote', 'helm_remote')
load('ext://helm_resource', 'helm_resource', 'helm_repo')

local_resource('Install Kustomize', cmd='make kustomize', deps=['Makefile', 'make/*'])
local_resource('Go Deps', cmd='make vendor', deps=['Makefile', 'go.mod', 'go.sum'])
local_resource('Build manifests', cmd='make manifests', deps=['Makefile', 'make/*', 'api/*'])
local_resource('Generate CRDs', cmd='make generate', deps=['Makefile', 'make/*', 'api/*'])
local_resource('Install CRDs', cmd='make install', deps=['Makefile', 'make/*', 'api/*'])

docker_build('localhost:5000/doltdb-operator:local', '.', dockerfile="Dockerfile")

k8s_yaml([
  'hack/manifests/storageclass.yaml', 
  'hack/manifests/e2e/snapshot.storage.k8s.io_volumesnapshots.yaml',
  'hack/manifests/doltdb-secret.yaml',
])

k8s_resource(
  objects=[
    'standard-resize:storageclass',
    'volumesnapshots.snapshot.storage.k8s.io:customresourcedefinition',
    'dolt-credentials:secret',
  ],
  new_name='Storage Class & Snapshotter CRDs'
)

k8s_yaml(kustomize('config/default'))
